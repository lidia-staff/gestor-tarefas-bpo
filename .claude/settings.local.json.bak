{
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "Atualize o arquivo C:\\Gestor de tarefas\\MASTER_LOG.md com o que foi implementado nesta sessão. Passos: 1) Leia C:\\Gestor de tarefas\\MASTER_LOG.md para entender o formato e o estado atual. 2) Analise o contexto da sessão (fornecido em $ARGUMENTS) para identificar: arquivos criados/alterados, funcionalidades implementadas, bugs corrigidos, pendências abertas. 3) Acrescente uma nova entrada de sessão com a data de hoje e descreva o que foi feito. Nunca apague conteúdo existente — apenas adicione. Mantenha o mesmo formato e estilo do arquivo.",
            "timeout": 120,
            "statusMessage": "Atualizando MASTER_LOG.md..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "agent",
            "prompt": "Atualize o arquivo C:\\Gestor de tarefas\\MASTER_LOG.md com o que foi implementado nesta sessão. Passos: 1) Leia C:\\Gestor de tarefas\\MASTER_LOG.md para entender o formato e o estado atual. 2) Analise o contexto da sessão (fornecido em $ARGUMENTS) para identificar: arquivos criados/alterados, funcionalidades implementadas, bugs corrigidos, pendências abertas. 3) Acrescente uma nova entrada de sessão com a data de hoje e descreva o que foi feito. Nunca apague conteúdo existente — apenas adicione. Mantenha o mesmo formato e estilo do arquivo.",
            "timeout": 120,
            "statusMessage": "Atualizando MASTER_LOG.md..."
          }
        ]
      }
    ]
  },
