# Copie para .env e preencha os valores

# Segredo JWT (gere uma string aleatória longa)
JWT_SECRET=troque_por_string_aleatoria_longa

# Diretório dos dados JSON (Railway: /data via Volume montado)
# Local: deixe vazio para usar ./data relativo ao projeto
DATA_DIR=

# Secret compartilhado com o intake bot e CA
WEBHOOK_SECRET=staffbot_email_2024

# URL e secret da API do Conta Azul (integração CA)
CA_API_URL=https://app.staffconsult.com.br
CA_API_SECRET=staffbot_email_2024

# Secret para criar o primeiro usuário master (remover após uso)
# Use: POST /api/bootstrap-master { secret, name, email, password }
BOOTSTRAP_SECRET=

# VAPID keys para Web Push (geradas automaticamente na primeira execução)
# Preencha após geração para persistir entre deploys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
